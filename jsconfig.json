{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": [
        "lib/*"
      ],
      "@keystone/*": [
        "keystone/*"
      ],
      "@storefront/*": [
        "storefront/*"
      ],
      "@modules/*": [
        "modules/*"
      ],
      "@pages/*": [
        "pages/*"
      ],
      "@svg": [
        "svg"
      ],
      "@keystone/components/*": [
        "keystone/themes/Tailwind/components/*"
      ],
      "@keystone/screens/*": [
        "keystone/themes/Tailwind/screens/*"
      ],
      "@keystone/views/*": [
        "keystone/themes/Tailwind/views/*"
      ]
    }
  },
  "include": [
    "**/*.js",
    "*.js",
    "keystone/themes/Tailwind/primitives/default/ui/accordion.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}